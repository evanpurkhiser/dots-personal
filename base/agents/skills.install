#!/usr/bin/env bash

source "$DOTS_SOURCE/base/bash/environment"

mkdir -p "$XDG_CONFIG_HOME/claude" "$XDG_CONFIG_HOME/opencode"

rm -rf "$XDG_CONFIG_HOME/claude/skills" "$XDG_CONFIG_HOME/opencode/skills"

ln -sfn "$XDG_CONFIG_HOME/agents/skills" "$XDG_CONFIG_HOME/claude/skills"
ln -sfn "$XDG_CONFIG_HOME/agents/skills" "$XDG_CONFIG_HOME/opencode/skills"
